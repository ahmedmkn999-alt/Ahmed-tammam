rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ✅ الطلاب: الطالب يقدر يكريت حساب، والقراءة والتعديل من السيرفر فقط
    match /students/{studentId} {
      allow create: if request.auth == null &&
                    request.resource.data.keys().hasAll(['fullName', 'studentPhone', 'password']) &&
                    request.resource.data.password is string &&
                    request.resource.data.password.size() == 64; // SHA-256 hex
      allow read, update, delete: if false; // السيرفر (Admin SDK) يتولى هذا
    }

    // 🔒 أكواد التفعيل: حماية قصوى من السرقة والتلاعب
    match /activation_codes/{codeId} {
      allow get: if true;   // يسمح بقراءة كود محدد فقط للفحص (get وليس list)
      allow list: if false;  // يمنع أي حد يسحب كل الأكواد اللي في الداتابيز
      allow write: if false; // التفعيل والتحديث يتم بأمان من خلال السيرفر (Admin SDK)
    }

    // ✅ رسائل الدعم: أي حد يكتب، مفيش حد يقرأ إلا الـ admin من السيرفر
    match /support_messages/{msgId} {
      allow create: if request.resource.data.keys().hasAll(['subject', 'body']) &&
                    request.resource.data.body.size() < 5000;
      allow read, update, delete: if false;
    }

    // ❌ كل باقي الـ collections ممنوعة
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
